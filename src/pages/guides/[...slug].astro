---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const guides = await getCollection("guides");

  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

interface Props {
  guide: any;
}

const { guide } = Astro.props as Props;

const data = guide.data;
const { Content } = await guide.render();

const pubDate =
  data?.pubDate instanceof Date
    ? data.pubDate
    : new Date(data?.pubDate ?? Date.now());

// Optional (you can add later to frontmatter; won't break if missing)
const authorName = data?.author ?? "SmallGrid";
const authorAvatar = data?.authorAvatar ?? "/images/authors/smallgrid.png";

const tags: string[] = Array.isArray(data?.tags) ? data.tags : [];

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "short",
    day: "2-digit",
  });

// Build a canonical-ish URL for sharing (works on Cloudflare Pages)
const shareUrl = Astro.url?.toString() ?? "";
const shareTitle = data?.title ?? "SmallGrid Guide";
const shareDescription = data?.description ?? "";

const enc = encodeURIComponent;
const shareLinks = {
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${enc(shareUrl)}`,
  x: `https://twitter.com/intent/tweet?url=${enc(shareUrl)}&text=${enc(shareTitle)}`,
  pinterest: `https://pinterest.com/pin/create/button/?url=${enc(shareUrl)}&description=${enc(
    `${shareTitle} — ${shareDescription}`.trim()
  )}`,
  email: `mailto:?subject=${enc(shareTitle)}&body=${enc(`${shareTitle}\n\n${shareUrl}`)}`,
};

const allGuides = await getCollection("guides", ({ data }) => !data.draft);
const guideBySlug = new Map(
  allGuides.map((item) => [
    item.slug,
    {
      title: item.data.title,
      description: item.data.description,
      url: `/guides/${item.slug}/`,
      cover: item.data.cover,
      tags: Array.isArray(item.data.tags) ? item.data.tags : [],
    },
  ])
);

const getGuideCards = (slugs: string[]) =>
  slugs
    .filter((slug) => slug !== guide.slug)
    .map((slug) => guideBySlug.get(slug))
    .filter(Boolean);

const jellyfinClusterSlugs = [
  "jellyfin-ubuntu-low-power",
  "jellyfin-ubuntu-folder-permissions",
  "jellyfin-media-library-not-showing-files",
  "jellyfin-docker-permissions-media-folder",
  "jellyfin-direct-play-vs-transcoding",
  "best-file-formats-for-jellyfin-direct-play",
  "best-mini-pc-specs-for-jellyfin",
  "jellyfin-hardware-transcoding-ubuntu",
  "jellyfin-tailscale-remote-access",
  "jellyfin-remote-access-safely",
  "jellyfin-mini-pc-home-server",
];

const nextGuideMap: Record<string, string[]> = {
  "jellyfin-ubuntu-low-power": [
    "jellyfin-ubuntu-folder-permissions",
    "jellyfin-direct-play-vs-transcoding",
    "jellyfin-tailscale-remote-access",
  ],
  "jellyfin-ubuntu-folder-permissions": [
    "jellyfin-media-library-not-showing-files",
    "jellyfin-docker-permissions-media-folder",
    "jellyfin-ubuntu-low-power",
  ],
  "jellyfin-media-library-not-showing-files": [
    "jellyfin-ubuntu-folder-permissions",
    "jellyfin-docker-permissions-media-folder",
    "jellyfin-direct-play-vs-transcoding",
  ],
  "jellyfin-docker-permissions-media-folder": [
    "jellyfin-media-library-not-showing-files",
    "jellyfin-ubuntu-folder-permissions",
    "jellyfin-direct-play-vs-transcoding",
  ],
  "jellyfin-direct-play-vs-transcoding": [
    "best-file-formats-for-jellyfin-direct-play",
    "jellyfin-hardware-transcoding-ubuntu",
    "best-mini-pc-specs-for-jellyfin",
  ],
  "best-file-formats-for-jellyfin-direct-play": [
    "jellyfin-direct-play-vs-transcoding",
    "jellyfin-hardware-transcoding-ubuntu",
    "best-mini-pc-specs-for-jellyfin",
  ],
  "best-mini-pc-specs-for-jellyfin": [
    "mini-pc-under-200",
    "jellyfin-mini-pc-home-server",
    "jellyfin-direct-play-vs-transcoding",
  ],
  "jellyfin-hardware-transcoding-ubuntu": [
    "jellyfin-direct-play-vs-transcoding",
    "best-file-formats-for-jellyfin-direct-play",
    "best-mini-pc-specs-for-jellyfin",
  ],
  "jellyfin-tailscale-remote-access": [
    "jellyfin-remote-access-safely",
    "jellyfin-ubuntu-low-power",
    "backups-3-2-1-home-server",
  ],
  "jellyfin-remote-access-safely": [
    "jellyfin-tailscale-remote-access",
    "jellyfin-ubuntu-low-power",
    "backups-3-2-1-home-server",
  ],
  "jellyfin-mini-pc-home-server": [
    "best-mini-pc-specs-for-jellyfin",
    "mini-pc-under-200",
    "measure-power-usage-homelab",
  ],
};

const checklistMap: Record<string, { title: string; description: string; href: string }[]> = {
  "jellyfin-media-library-not-showing-files": [
    {
      title: "Jellyfin Media Not Showing Checklist",
      description: "Work through paths, mounts, scans, logs, and folder access in the right order.",
      href: "/downloads/checklists/jellyfin-media-not-showing-checklist.pdf",
    },
    {
      title: "Jellyfin Folder Permissions Checklist",
      description: "Test folder access as the jellyfin user and apply safer ACL permissions.",
      href: "/downloads/checklists/jellyfin-folder-permissions-checklist.pdf",
    },
  ],
  "jellyfin-ubuntu-folder-permissions": [
    {
      title: "Jellyfin Folder Permissions Checklist",
      description: "A printable Ubuntu checklist for testing and fixing Jellyfin media folder access.",
      href: "/downloads/checklists/jellyfin-folder-permissions-checklist.pdf",
    },
  ],
  "jellyfin-docker-permissions-media-folder": [
    {
      title: "Jellyfin Docker Permissions Checklist",
      description: "Check host paths, container paths, bind mounts, users, and read-only volumes.",
      href: "/downloads/checklists/jellyfin-docker-permissions-checklist.pdf",
    },
  ],
  "jellyfin-direct-play-vs-transcoding": [
    {
      title: "Jellyfin Direct Play Checklist",
      description: "Check codecs, audio, subtitles, clients, and 4K playback before changing hardware.",
      href: "/downloads/checklists/jellyfin-direct-play-checklist.pdf",
    },
  ],
  "best-file-formats-for-jellyfin-direct-play": [
    {
      title: "Jellyfin Direct Play Checklist",
      description: "A quick format and playback checklist to reduce unnecessary transcoding.",
      href: "/downloads/checklists/jellyfin-direct-play-checklist.pdf",
    },
  ],
  "best-mini-pc-specs-for-jellyfin": [
    {
      title: "Jellyfin Mini PC Buying Checklist",
      description: "Check CPU, Quick Sync, RAM, SSD, networking, storage, and power use before buying.",
      href: "/downloads/checklists/jellyfin-mini-pc-buying-checklist.pdf",
    },
  ],
  "jellyfin-mini-pc-home-server": [
    {
      title: "Jellyfin Mini PC Buying Checklist",
      description: "A practical checklist for choosing a quiet low-power Jellyfin mini PC.",
      href: "/downloads/checklists/jellyfin-mini-pc-buying-checklist.pdf",
    },
  ],
  "mini-pc-under-200": [
    {
      title: "Jellyfin Mini PC Buying Checklist",
      description: "Use this when comparing used mini PCs for a small Jellyfin server.",
      href: "/downloads/checklists/jellyfin-mini-pc-buying-checklist.pdf",
    },
  ],
};

const checklistDownloads = checklistMap[guide.slug] ?? [];
const nextGuides = getGuideCards(nextGuideMap[guide.slug] ?? []);
const jellyfinCluster = tags.includes("jellyfin") ? getGuideCards(jellyfinClusterSlugs).slice(0, 6) : [];
const isJellyfinGuide = tags.includes("jellyfin") || guide.slug.includes("jellyfin");
const isProxmoxGuide = tags.includes("proxmox") || guide.slug.includes("proxmox");
const guideDifficulty = isProxmoxGuide ? "Beginner to intermediate" : "Beginner-friendly";
const guideFocus = isJellyfinGuide
  ? "Jellyfin setup and troubleshooting"
  : isProxmoxGuide
    ? "Small home lab virtualisation"
    : "Small home server setup";
const quickAnswer = data.description;
---

<BaseLayout title={data.title} description={data.description} canonicalPath={`/guides/${guide.slug}/`}>
  <header class="article-header">
    <p class="article-kicker">Guide · SmallGrid</p>

    <h1 class="article-title">{data.title}</h1>

    {data.cover ? (
      <div class="article-hero">
        <img class="cover-image" src={data.cover} alt={data.title} loading="lazy" />
        <div class="article-hero-meta">
          <div class="guide-byline">
            <img class="guide-avatar" src={authorAvatar} alt="" width="36" height="36" loading="lazy" />
            <span class="guide-byline-text">
              <span class="muted">by</span> <span class="guide-author">{authorName}</span>
            </span>
          </div>

          <div style="margin-left:auto; display:flex; gap:0.6rem; align-items:center;">
            <div class="reading-time" id="reading-time">…</div>
            <div class="guide-meta-chips" aria-hidden>
              <span class="chip">
                <span class="chip-label">Updated</span>
                <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
              </span>
            </div>
          </div>
        </div>
      </div>
    ) : null}

    <div class="guide-topline">
        <div style="display:none;"> <!-- kept for accessibility/fallback -->
          <div class="guide-byline">
            <img class="guide-avatar" src={authorAvatar} alt="" width="36" height="36" loading="lazy" />
            <span class="guide-byline-text">
              <span class="muted">by</span> <span class="guide-author">{authorName}</span>
            </span>
          </div>

          <div class="guide-meta-chips">
            <span class="chip">
              <span class="chip-label">Updated</span>
              <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            </span>

            {tags.slice(0, 6).map((tag) => (
              <span class="chip chip-tag">#{tag}</span>
            ))}
          </div>
        </div>
    </div>

    <div class="guide-toolbar" data-guide-slug={guide.slug}>
      <div class="guide-share">
        <a class="icon-btn" href={shareLinks.facebook} target="_blank" rel="noreferrer" aria-label="Share on Facebook" title="Share on Facebook">
          f
        </a>
        <a class="icon-btn" href={shareLinks.x} target="_blank" rel="noreferrer" aria-label="Share on X" title="Share on X">
          x
        </a>
        <a class="icon-btn" href={shareLinks.pinterest} target="_blank" rel="noreferrer" aria-label="Share on Pinterest" title="Share on Pinterest">
          p
        </a>
        <a class="icon-btn" href={shareLinks.email} aria-label="Share by email" title="Share by email">
          @
        </a>
        <button class="icon-btn" type="button" data-action="copy" aria-label="Copy link" title="Copy link">
          ⧉
        </button>
      </div>

      <div class="guide-actions">
        <button class="btn btn-primary" type="button" data-action="print">
          Save as PDF
        </button>

        <button class="btn btn-ghost" type="button" data-action="status" aria-live="polite">
          Not Started
        </button>

        <button class="heart-btn" type="button" data-action="favorite" aria-pressed="false" aria-label="Save this guide">
          ♥
        </button>
      </div>
    </div>

    <div class="guide-note" role="note">
      Heads up: SmallGrid doesn’t do affiliate fluff. If we ever use affiliate links in the future, we’ll say so clearly on the page.
    </div>
  </header>

  <hr class="article-divider" />

  <div class="article-grid">
    <article class="article-body">
      <section class="card" style="margin-bottom:1.25rem; background:linear-gradient(135deg,#f4fbfb,#ffffff); border:1px solid rgba(14,61,57,0.14);">
        <p class="kicker">Quick answer</p>
        <h2 style="margin-top:0;">What this guide helps you do</h2>
        <p style="font-size:1.03rem; margin-bottom:0;">{quickAnswer}</p>
      </section>

      <section class="grid" style="margin-bottom:1.25rem;">
        <article class="card" style="padding:1rem; border-left:4px solid #0e3d39;">
          <p class="kicker">Difficulty</p>
          <h3 style="margin:0; font-size:1rem;">{guideDifficulty}</h3>
        </article>
        <article class="card" style="padding:1rem; border-left:4px solid #0a66ff;">
          <p class="kicker">Focus</p>
          <h3 style="margin:0; font-size:1rem;">{guideFocus}</h3>
        </article>
        <article class="card" style="padding:1rem; border-left:4px solid #2fa4a9;">
          <p class="kicker">Best used for</p>
          <h3 style="margin:0; font-size:1rem;">Practical setup, fixes, and checks</h3>
        </article>
      </section>

      {checklistDownloads.length ? (
        <section class="card" style="margin-bottom:1.25rem; background:linear-gradient(135deg,#0e3d39,#0b4f49); color:#ffffff; border:0;">
          <p class="kicker" style="color:rgba(255,255,255,0.78);">Printable helper</p>
          <h2 style="margin-top:0; color:#ffffff;">Prefer to work through this step by step?</h2>
          <p style="color:rgba(255,255,255,0.88);">
            Download the matching checklist and tick off the common causes while you work through the guide.
          </p>
          <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:1rem;">
            {checklistDownloads.map((item) => (
              <a class="btn" href={item.href} download style="background:#ffffff;">{item.title}</a>
            ))}
          </div>
        </section>
      ) : null}

      <Content />

      {checklistDownloads.length ? (
        <section class="card" style="margin-top:2rem; background:linear-gradient(135deg,#0e3d39,#0b4f49); color:#ffffff; border:0;">
          <p class="kicker" style="color:rgba(255,255,255,0.78);">Downloadable checklist</p>
          <h2 style="margin-top:0; color:#ffffff;">Save the matching PDF checklist</h2>
          <p style="color:rgba(255,255,255,0.88);">
            Use these while working through the guide, or keep a copy for the next time the same problem appears.
          </p>
          <div class="grid" style="margin-top:1rem;">
            {checklistDownloads.map((item) => (
              <article class="card" style="padding:1rem; background:#ffffff; color:#1f2428;">
                <h3 style="margin-top:0; font-size:1rem;"><a href={item.href} download>{item.title}</a></h3>
                <p class="muted">{item.description}</p>
                <a class="btn primary" href={item.href} download>Download PDF</a>
              </article>
            ))}
          </div>
          <p style="color:rgba(255,255,255,0.82); margin-bottom:0; margin-top:1rem; font-size:0.95rem;">
            More downloads are available in the <a href="/checklists/" style="color:#ffffff; text-decoration:underline;">SmallGrid checklists section</a>.
          </p>
        </section>
      ) : null}

      {nextGuides.length ? (
        <section class="card" style="margin-top:2rem; background:linear-gradient(135deg,#f4fbfb,#ffffff); border:1px solid rgba(14,61,57,0.14);">
          <p class="kicker">Next guide</p>
          <h2 style="margin-top:0;">What to read next</h2>
          <p class="muted">
            Continue the setup path with these closely related guides.
          </p>
          <div class="grid" style="margin-top:1rem;">
            {nextGuides.map((item: any) => (
              <article class="card hover" style="padding:1rem;">
                <h3 style="margin-top:0; font-size:1rem;"><a href={item.url}>{item.title}</a></h3>
                <p class="muted" style="margin-bottom:0;">{item.description}</p>
              </article>
            ))}
          </div>
        </section>
      ) : null}

      {jellyfinCluster.length ? (
        <section class="card" style="margin-top:1rem; background:#ffffff; border:1px solid rgba(10,102,255,0.14);">
          <p class="kicker">Jellyfin guide cluster</p>
          <h2 style="margin-top:0;">More Jellyfin fixes and setup guides</h2>
          <p class="muted">
            These guides link the main Jellyfin setup, permissions, remote access, direct play, and hardware topics together.
          </p>
          <div class="grid" style="margin-top:1rem;">
            {jellyfinCluster.map((item: any) => (
              <article class="card hover" style="padding:1rem;">
                <h3 style="margin-top:0; font-size:1rem;"><a href={item.url}>{item.title}</a></h3>
                <p class="muted" style="margin-bottom:0;">{item.description}</p>
              </article>
            ))}
          </div>
        </section>
      ) : null}
    </article>

    <aside class="toc" aria-label="Contents">
      <h4>Contents</h4>
      <nav>
        <ul class="toc-list" id="toc-list"></ul>
      </nav>
    </aside>
  </div>

  <script is:inline>
    (() => {
      const root = document.querySelector(".guide-toolbar");
      if (!root) return;

      const slug = root.getAttribute("data-guide-slug") || "guide";
      const keyStatus = `sg:guide:status:${slug}`;
      const keyFav = `sg:guide:fav:${slug}`;

      const statusBtn = root.querySelector('[data-action="status"]');
      const favBtn = root.querySelector('[data-action="favorite"]');
      const copyBtn = root.querySelector('[data-action="copy"]');
      const printBtn = root.querySelector('[data-action="print"]');

      const statuses = ["Not Started", "In Progress", "Done"];

      function setStatus(label) {
        if (!statusBtn) return;
        statusBtn.textContent = label;
        try { localStorage.setItem(keyStatus, label); } catch (_) {}
      }

      function getStatus() {
        try { return localStorage.getItem(keyStatus); } catch (_) { return null; }
      }

      function setFav(isFav) {
        if (!favBtn) return;
        favBtn.classList.toggle("is-faved", isFav);
        favBtn.setAttribute("aria-pressed", String(isFav));
        try { localStorage.setItem(keyFav, isFav ? "1" : "0"); } catch (_) {}
      }

      function getFav() {
        try { return localStorage.getItem(keyFav) === "1"; } catch (_) { return false; }
      }

      // Init from storage
      const savedStatus = getStatus();
      if (savedStatus && statuses.includes(savedStatus)) setStatus(savedStatus);
      else setStatus("Not Started");

      setFav(getFav());

      statusBtn?.addEventListener("click", () => {
        const current = statusBtn.textContent || "Not Started";
        const idx = statuses.indexOf(current);
        const next = statuses[(idx + 1) % statuses.length];
        setStatus(next);
      });

      favBtn?.addEventListener("click", () => {
        setFav(!favBtn.classList.contains("is-faved"));
      });

      copyBtn?.addEventListener("click", async () => {
        const url = window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          copyBtn.textContent = "✓";
          setTimeout(() => (copyBtn.textContent = "⧉"), 900);
        } catch (_) {
          // fallback: best-effort
          copyBtn.textContent = "…";
          setTimeout(() => (copyBtn.textContent = "⧉"), 900);
        }
      });

      printBtn?.addEventListener("click", () => {
        window.print();
      });

      // Generate reading time and table of contents
      (function () {
        try {
          const content = document.querySelector('.article-body');
          if (!content) return;

          // Reading time: ~200 WPM
          const text = content.textContent || '';
          const words = text.trim().split(/\s+/).filter(Boolean).length;
          const minutes = Math.max(1, Math.round(words / 200));
          const rt = document.getElementById('reading-time');
          if (rt) rt.textContent = `${minutes} min read`;

          // Table of contents
          const tocList = document.getElementById('toc-list');
          if (!tocList) return;
          const headings = content.querySelectorAll('h2, h3');
          headings.forEach((h) => {
            if (!h.id) {
              h.id = h.textContent.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');
            }
            const li = document.createElement('li');
            li.style.marginLeft = h.tagName.toLowerCase() === 'h3' ? '0.6rem' : '0';
            const a = document.createElement('a');
            a.href = `#${h.id}`;
            a.textContent = h.textContent;
            a.setAttribute('data-target', h.id);
            li.appendChild(a);
            tocList.appendChild(li);
          });

          // Active-section highlighting using IntersectionObserver
          const tocLinks = Array.from(tocList.querySelectorAll('a'));
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                const id = entry.target.id;
                const link = tocList.querySelector(`a[data-target="${id}"]`);
                if (!link) return;
                if (entry.isIntersecting) {
                  tocLinks.forEach((l) => l.classList.remove('active'));
                  link.classList.add('active');
                }
              });
            },
            { root: null, rootMargin: '0px 0px -60% 0px', threshold: 0 }
          );

          headings.forEach((h) => observer.observe(h));
        } catch (e) {
          // ignore small failures
        }
      })();
    })();
  </script>
</BaseLayout>
