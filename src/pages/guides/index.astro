---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const guidesAll = await getCollection("guides", ({ data }) => !data.draft);
const guides = guidesAll.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredCovers = guides.filter((g) => g.data.cover).slice(0, 3);

const allTags = Array.from(new Set(guides.flatMap((g) => g.data.tags || []))).sort((a, b) =>
  a.localeCompare(b)
);

const searchUrlForTag = (tag: string) => `/search/?q=${encodeURIComponent(tag)}`;

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-GB", { year: "numeric", month: "short", day: "2-digit" });
---

<BaseLayout
  title="Guides · SmallGrid"
  description="Practical tutorials for quiet, low-power homelabs: Jellyfin, mini PCs, simple networking, and backups."
  canonicalPath="/guides/"
>
  <section class="card" style="overflow:hidden; background: radial-gradient(circle at top right, rgba(10,102,255,0.18), transparent 32%), radial-gradient(circle at top left, rgba(14,61,57,0.16), transparent 34%), linear-gradient(135deg, #ffffff, #f4fbfb);">
    <p class="kicker">Guides · SmallGrid</p>
    <h1 style="margin:0 0 0.75rem;">Guides</h1>
    <p class="muted" style="margin:0; font-size:1.05rem; max-width:760px;">
      Practical and opinionated setups for small, efficient homelabs. No port-forwarding heroics. No rack cosplay. Just clear fixes, sensible defaults, and systems you can actually maintain.
    </p>

    {featuredCovers.length ? (
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 0.75rem; margin-top: 1rem;">
        {featuredCovers.map((post) => (
          <a href={`/guides/${post.slug}/`} aria-label={`Read ${post.data.title}`} style="display:block; text-decoration:none;">
            <img src={post.data.cover} alt="" loading="lazy" decoding="async" style="width:100%; height:135px; object-fit:contain; background:#f7f9fa; border-radius:0.75rem; border:1px solid rgba(107,115,123,0.16);" />
          </a>
        ))}
      </div>
    ) : null}

    {allTags.length > 0 && (
      <div style="margin-top: 1rem;">
        <div class="muted" style="font-size: 13px; margin-bottom: 0.35rem;">Popular tags</div>
        <div style="display:flex; flex-wrap:wrap; gap:0.35rem;">
          {allTags.map((tag) => (
            <a
              class="pill"
              href={searchUrlForTag(tag)}
              aria-label={`Search SmallGrid for ${tag}`}
              style="text-decoration:none;"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  <section class="card" style="margin-top:16px; background:linear-gradient(135deg,#0e3d39,#0b4f49); color:#ffffff;">
    <div class="kicker" style="color:rgba(255,255,255,0.78);">Guide library</div>
    <h2 style="color:#ffffff; margin-top:0;">Pick the problem you are solving now.</h2>
    <p style="color:rgba(255,255,255,0.88); margin-bottom:0;">
      Start with the guide that matches the thing currently blocking progress: Jellyfin permissions, power usage, backups, safe updates, storage, remote access, or hardware choices.
    </p>
  </section>

  <section class="guide-grid" aria-label="All guides" style="margin-top:16px;">
    {guides.map((post) => (
      <article class="guide-card">
        {post.data.cover ? (
          <a class="guide-card-cover-link" href={`/guides/${post.slug}/`} aria-label={`Read ${post.data.title}`}>
            <img
              class="guide-card-cover"
              src={post.data.cover}
              alt=""
              loading="lazy"
              decoding="async"
            />
          </a>
        ) : null}

        <h2 class="guide-card-title">
          <a class="guide-card-link" href={`/guides/${post.slug}/`}>
            {post.data.title}
          </a>
        </h2>

        <div class="guide-card-meta">
          <span>{formatDate(post.data.pubDate)}</span>
          {post.data.updatedDate ? <span>· Updated {formatDate(post.data.updatedDate)}</span> : null}
        </div>

        <p class="guide-card-desc">{post.data.description}</p>

        {(post.data.tags || []).length ? (
          <ul class="guide-card-tags">
            {(post.data.tags || []).slice(0, 6).map((tag) => (
              <li>
                <a
                  class="tag-pill"
                  href={searchUrlForTag(tag)}
                  aria-label={`Search SmallGrid for ${tag}`}
                  style="display:inline-flex; text-decoration:none;"
                >
                  #{tag}
                </a>
              </li>
            ))}
          </ul>
        ) : null}
      </article>
    ))}
  </section>
</BaseLayout>
