---
import BaseLayout from "../layouts/BaseLayout.astro";

const buildTiers = [
  {
    tier: "Budget friendly",
    bestFor: "First homelab, Jellyfin testing, Pi-hole, Home Assistant, basic Docker services.",
    coreBox: "Used mini PC: Dell OptiPlex Micro, Lenovo ThinkCentre Tiny, HP EliteDesk Mini, or similar.",
    targetSpec: "Intel 8th gen i5 or newer, or equivalent AMD; 16 GB RAM; 256–512 GB NVMe SSD.",
    storage: "1 TB SSD for apps plus an external USB HDD for media or backups.",
    network: "Existing router, one small unmanaged gigabit switch if needed.",
    avoid: "Old thin clients with very weak CPUs, unknown power supplies, noisy rack servers, and machines with no upgrade path.",
  },
  {
    tier: "Mid range",
    bestFor: "A reliable always-on home server running Jellyfin, Docker containers, backups, monitoring, and light virtual machines.",
    coreBox: "Newer used business mini PC or compact workstation: Intel i5/i7 10th–13th gen, Ryzen 5/7 mini PC, or similar.",
    targetSpec: "6–8 useful CPU cores, 32 GB RAM, 1 TB NVMe SSD, Intel Quick Sync or capable integrated graphics for Jellyfin.",
    storage: "1 TB NVMe for services, 2–8 TB HDD or NAS storage for media, separate backup drive.",
    network: "Gigabit switch as baseline; consider 2.5 GbE if moving large media files regularly.",
    avoid: "Overspending on CPU before sorting backups, storage layout, and network reliability.",
  },
  {
    tier: "Top spec",
    bestFor: "Heavy self-hosting, multiple VMs, large media libraries, fast storage, lab testing, and future expansion.",
    coreBox: "Compact workstation, small tower server, or efficient custom build with room for more RAM, storage, and NIC upgrades.",
    targetSpec: "8–16 cores, 64 GB+ RAM, multiple NVMe slots, 2.5/10 GbE option, and enough cooling without excessive noise.",
    storage: "Mirrored SSDs for services, dedicated bulk storage, external/offsite backup, and a UPS sized for graceful shutdown.",
    network: "Managed switch, VLAN-capable router/firewall, 2.5 GbE or 10 GbE where it actually helps.",
    avoid: "Buying enterprise rack gear purely because it is cheap upfront. Noise, power draw, and heat become the real cost.",
  },
];

const categories = [
  {
    title: "Mini PC or server",
    budget: "Used office mini PC with 8th gen Intel i5 or newer, 16 GB RAM, and NVMe storage.",
    mid: "Newer business mini PC or Ryzen mini PC with 32 GB RAM and stronger integrated graphics.",
    top: "Compact workstation or efficient tower with 64 GB+ RAM, multiple drives, and upgradeable networking.",
  },
  {
    title: "Memory",
    budget: "16 GB RAM. Enough for Linux, Docker, Jellyfin, Pi-hole, and light services.",
    mid: "32 GB RAM. The sweet spot for Proxmox, several containers, and a few small VMs.",
    top: "64 GB or more. Useful for heavier virtualisation, databases, labs, and test environments.",
  },
  {
    title: "Primary storage",
    budget: "256–512 GB NVMe SSD for OS and containers.",
    mid: "1 TB NVMe SSD for OS, containers, VM disks, downloads, and metadata.",
    top: "Multiple NVMe SSDs, ideally with a mirrored or backed-up service volume.",
  },
  {
    title: "Bulk storage",
    budget: "Single external HDD for media or backups, with a second copy elsewhere.",
    mid: "NAS-grade HDD or small DAS/NAS for media, backups, and snapshots.",
    top: "Dedicated NAS, mirrored storage, larger backup target, and offsite copy.",
  },
  {
    title: "Networking",
    budget: "Use your existing router and add a small unmanaged gigabit switch if needed.",
    mid: "Reliable gigabit or 2.5 GbE switch, tidy cabling, and labelled ports.",
    top: "Managed switch, VLAN-capable firewall/router, 2.5/10 GbE where large file transfers justify it.",
  },
  {
    title: "Power protection",
    budget: "Basic surge-protected extension and sensible cable management.",
    mid: "Small UPS with USB shutdown support for one server and storage device.",
    top: "UPS sized for server, network gear, and storage, with tested automatic shutdown.",
  },
];
---

<BaseLayout
  title="Recommended Home Lab Gear"
  description="Budget friendly, mid range, and top spec equipment suggestions for building a quiet, useful home lab or Jellyfin server."
  canonicalPath="/recommended-gear/"
>
  <section class="card">
    <div class="kicker">Home lab buying guide</div>
    <h1>Recommended gear for a SmallGrid-style home lab</h1>
    <p>
      This guide is designed for people building a practical home lab, media server, or small self-hosted setup without wasting money on noisy, power-hungry equipment.
    </p>
    <p>
      The goal is not to chase the highest benchmark score. The goal is to buy equipment that is quiet, affordable, reliable, easy to back up, and powerful enough for the services you actually want to run.
    </p>
    <p class="guide-note">
      Prices and availability change constantly, especially on used business hardware. Treat the model examples as search terms and buying criteria, not as a fixed shopping list.
    </p>
  </section>

  <section class="card" style="margin-top: 16px;">
    <h2>Quick recommendation</h2>
    <p>
      For most beginners, the best starting point is a used business mini PC with an Intel 8th generation i5 or newer, 16–32 GB RAM, and an NVMe SSD. It is usually quiet, cheap to run, easy to replace, and powerful enough for Jellyfin, Docker, Pi-hole, Home Assistant, Tailscale, backups, and a small Proxmox setup.
    </p>
    <p>
      Only move to larger servers, rack equipment, or custom builds once you know you actually need more drive bays, more RAM, faster networking, or heavier virtualisation.
    </p>
  </section>

  <section class="grid" style="margin-top: 16px;">
    {buildTiers.map((item) => (
      <article class="card">
        <div class="kicker">{item.tier}</div>
        <h2>{item.tier} home lab setup</h2>
        <p><strong>Best for:</strong> {item.bestFor}</p>
        <ul>
          <li><strong>Core box:</strong> {item.coreBox}</li>
          <li><strong>Target spec:</strong> {item.targetSpec}</li>
          <li><strong>Storage:</strong> {item.storage}</li>
          <li><strong>Network:</strong> {item.network}</li>
          <li><strong>Avoid:</strong> {item.avoid}</li>
        </ul>
      </article>
    ))}
  </section>

  <section class="card" style="margin-top: 16px; overflow-x: auto;">
    <h2>Budget vs mid range vs top spec</h2>
    <p>
      Use this table to decide where to spend and where to hold back.
    </p>

    <table style="width: 100%; border-collapse: collapse; min-width: 760px;">
      <thead>
        <tr>
          <th style="text-align: left; border-bottom: 1px solid rgba(107, 115, 123, 0.25); padding: 0.65rem;">Category</th>
          <th style="text-align: left; border-bottom: 1px solid rgba(107, 115, 123, 0.25); padding: 0.65rem;">Budget friendly</th>
          <th style="text-align: left; border-bottom: 1px solid rgba(107, 115, 123, 0.25); padding: 0.65rem;">Mid range</th>
          <th style="text-align: left; border-bottom: 1px solid rgba(107, 115, 123, 0.25); padding: 0.65rem;">Top spec</th>
        </tr>
      </thead>
      <tbody>
        {categories.map((item) => (
          <tr>
            <td style="vertical-align: top; border-bottom: 1px solid rgba(107, 115, 123, 0.18); padding: 0.65rem;"><strong>{item.title}</strong></td>
            <td style="vertical-align: top; border-bottom: 1px solid rgba(107, 115, 123, 0.18); padding: 0.65rem;">{item.budget}</td>
            <td style="vertical-align: top; border-bottom: 1px solid rgba(107, 115, 123, 0.18); padding: 0.65rem;">{item.mid}</td>
            <td style="vertical-align: top; border-bottom: 1px solid rgba(107, 115, 123, 0.18); padding: 0.65rem;">{item.top}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="grid" style="margin-top: 16px;">
    <article class="card">
      <div class="kicker">Core box</div>
      <h2>What to look for in a mini PC</h2>
      <ul>
        <li>Intel 8th gen or newer if you want a safe used buying baseline.</li>
        <li>Intel Quick Sync is useful for Jellyfin hardware transcoding.</li>
        <li>Two RAM slots are better than soldered memory.</li>
        <li>NVMe storage keeps the system responsive.</li>
        <li>USB 3.x ports are useful for temporary drives, backup disks, and installers.</li>
        <li>Check that the power supply is included and genuine.</li>
      </ul>
    </article>

    <article class="card">
      <div class="kicker">Storage</div>
      <h2>How to avoid storage regret</h2>
      <ul>
        <li>Keep the OS and services on SSD/NVMe storage.</li>
        <li>Use larger HDDs for media, archives, and backups.</li>
        <li>Do not treat one external drive as a backup if it is the only copy.</li>
        <li>Plan for restore testing, not just backup creation.</li>
        <li>Quiet drives and good placement matter if the server is in a living space.</li>
      </ul>
    </article>

    <article class="card">
      <div class="kicker">Network</div>
      <h2>Networking worth buying</h2>
      <ul>
        <li>Gigabit Ethernet is enough for most beginner setups.</li>
        <li>2.5 GbE is useful for frequent large media transfers.</li>
        <li>10 GbE is excellent but often overkill unless storage can keep up.</li>
        <li>Label cables and ports early. It saves time later.</li>
        <li>Avoid building around Wi-Fi if the server can be wired.</li>
      </ul>
    </article>
  </section>

  <section class="grid" style="margin-top: 16px;">
    <article class="card">
      <div class="kicker">Budget traps</div>
      <h2>Cheap hardware that can cost more later</h2>
      <ul>
        <li>Old rack servers that are cheap to buy but loud and expensive to run.</li>
        <li>Very old CPUs with poor idle power use.</li>
        <li>Systems that need rare RAM, adapters, or proprietary power supplies.</li>
        <li>External drive enclosures with poor cooling.</li>
        <li>No-name power bricks and unsafe extension leads.</li>
      </ul>
    </article>

    <article class="card">
      <div class="kicker">Good extras</div>
      <h2>Low-cost upgrades that help</h2>
      <ul>
        <li>Rubber feet or a dense mat to reduce vibration.</li>
        <li>Short Ethernet cables and labels.</li>
        <li>A dedicated USB installer drive.</li>
        <li>A basic power meter to measure real usage.</li>
        <li>A spare backup drive kept disconnected when not in use.</li>
      </ul>
    </article>

    <article class="card">
      <div class="kicker">Buying rule</div>
      <h2>The SmallGrid buying rule</h2>
      <p>
        Buy the smallest reliable system that solves the job now, with one sensible upgrade path for later.
      </p>
      <p>
        That usually beats buying a huge server first and then trying to make it quiet, cheap, and simple afterwards.
      </p>
    </article>
  </section>

  <section class="card" style="margin-top: 16px;">
    <h2>Suggested buying path</h2>
    <ol>
      <li><strong>Start with the core box:</strong> used mini PC, 16–32 GB RAM, NVMe SSD.</li>
      <li><strong>Add storage:</strong> external HDD, NAS, or DAS depending on how much media or backup space you need.</li>
      <li><strong>Add power protection:</strong> surge protection first, then UPS once the server becomes important.</li>
      <li><strong>Improve networking:</strong> wired gigabit first, then 2.5 GbE or managed networking if there is a real use case.</li>
      <li><strong>Upgrade only when a limit is obvious:</strong> CPU, RAM, storage, network, or reliability.</li>
    </ol>
    <p>
      This keeps the project practical and avoids turning a useful home lab into a permanent shopping list.
    </p>
    <div class="guide-actions" style="margin-top: 1rem;">
      <a class="btn primary" href="/start/">Start the full setup path →</a>
      <a class="btn" href="/guides/mini-pc-under-200/">Read the mini PC guide →</a>
    </div>
  </section>
</BaseLayout>
