---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const guidesAll = await getCollection("guides", ({ data }) => !data.draft);
const guides = guidesAll.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = guides.slice(0, 6);
const guideBySlug = new Map(guides.map((guide) => [guide.slug, guide]));

const findGuide = (slug: string) => guideBySlug.get(slug);

const priorityGuides = [
  findGuide("jellyfin-media-library-not-showing-files"),
  findGuide("jellyfin-docker-permissions-media-folder"),
  findGuide("best-file-formats-for-jellyfin-direct-play"),
  findGuide("best-mini-pc-specs-for-jellyfin"),
].filter(Boolean);

const beginnerPaths = [
  {
    kicker: "Fix Jellyfin",
    title: "My Jellyfin library is empty",
    body: "Check paths, mounted drives, folder permissions, Docker volume mappings, and library scans before reinstalling anything.",
    href: "/guides/jellyfin-media-library-not-showing-files/",
    linkText: "Fix Jellyfin files →",
    accent: "#0e3d39",
  },
  {
    kicker: "Build",
    title: "I want a small home server",
    body: "Start with one low-power mini PC, one useful service, a clean folder structure, and a backup plan you can actually test.",
    href: "/start/",
    linkText: "Follow the starter path →",
    accent: "#0a66ff",
  },
  {
    kicker: "Buy smarter",
    title: "I need a Jellyfin mini PC",
    body: "Focus on idle power, Intel Quick Sync, enough RAM, SSD storage, and reliable networking instead of headline CPU scores.",
    href: "/guides/best-mini-pc-specs-for-jellyfin/",
    linkText: "Choose Jellyfin specs →",
    accent: "#2fa4a9",
  },
  {
    kicker: "Protect it",
    title: "I need backups that restore",
    body: "Use boring, testable backups before adding more services. Snapshots are useful, but they are not a full backup plan.",
    href: "/guides/backups-3-2-1-home-server/",
    linkText: "Set up backups →",
    accent: "#0e3d39",
  },
];

const journalAll = await getCollection("journal", ({ data }) => !data.draft);
const journalSorted = journalAll.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestJournal = journalSorted[0];
---

<BaseLayout
  title="Small, efficient home labs"
  description="Build a small efficient home lab with low-power mini PCs, Jellyfin, simple networking, quiet storage, and backups that actually restore."
  canonicalPath="/"
>
  <section class="card" style="overflow:hidden; background: radial-gradient(circle at top right, rgba(10,102,255,0.18), transparent 32%), radial-gradient(circle at top left, rgba(14,61,57,0.16), transparent 34%), linear-gradient(135deg, #ffffff, #f4fbfb);">
    <div class="kicker">Tiny tools. Solid systems.</div>
    <h1>Beginner-friendly home lab guides that fix real problems.</h1>
    <p style="font-size:1.08rem; max-width:820px;">
      SmallGrid helps you build a quiet, low-power home server around Jellyfin, mini PCs, safe remote access, practical backups, and troubleshooting steps that do not assume you already know everything.
    </p>

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 0.75rem; margin: 1rem 0;">
      <img src="/images/guides/jellyfin-ubuntu-low-power-hero.webp" alt="" loading="lazy" decoding="async" style="width:100%; height:135px; object-fit:contain; background:#f7f9fa; border-radius:0.75rem; border:1px solid rgba(107,115,123,0.16);" />
      <img src="/images/guides/mini-pc-under-200-hero.webp" alt="" loading="lazy" decoding="async" style="width:100%; height:135px; object-fit:contain; background:#f7f9fa; border-radius:0.75rem; border:1px solid rgba(107,115,123,0.16);" />
      <img src="/images/guides/jellyfin-media-library-not-showing-files-hero.webp" alt="" loading="lazy" decoding="async" style="width:100%; height:135px; object-fit:contain; background:#f7f9fa; border-radius:0.75rem; border:1px solid rgba(107,115,123,0.16);" />
    </div>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top: 10px;">
      <a class="btn primary" href="/start/">Start here</a>
      <a class="btn" href="/guides/jellyfin/">Jellyfin guides</a>
      <a class="btn" href="/checklists/">Download checklists</a>
      <a class="btn" href="/recommended-gear/">Recommended gear</a>
      <a class="btn" href="/guides/">Browse all guides</a>
    </div>
  </section>

  <section class="grid" style="margin-top: 16px;">
    {beginnerPaths.map((path) => (
      <article class="card hover" style={`border-top:4px solid ${path.accent}; background:linear-gradient(180deg,#ffffff,#f7fbfb);`}>
        <div class="kicker">{path.kicker}</div>
        <h2>{path.title}</h2>
        <p>{path.body}</p>
        <a class="btn" href={path.href}>{path.linkText}</a>
      </article>
    ))}
  </section>

  <section class="card" style="margin-top:16px; background:linear-gradient(135deg,#0e3d39,#0b4f49); color:#ffffff;">
    <div class="kicker" style="color:rgba(255,255,255,0.78);">Most useful first</div>
    <h2 style="color:#ffffff; margin-top:0;">Trying to fix Jellyfin?</h2>
    <p style="color:rgba(255,255,255,0.88); max-width:820px;">
      The fastest wins are usually not hardware upgrades. They are path checks, mounted drives, Linux permissions, Docker volume mappings, direct play settings, and a clear folder structure.
    </p>
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:1rem;">
      <a class="btn primary" href="/guides/jellyfin/">Open the Jellyfin hub →</a>
      <a class="btn" href="/guides/jellyfin-media-library-not-showing-files/" style="background:#ffffff;">Fix an empty library</a>
      <a class="btn" href="/downloads/checklists/jellyfin-media-not-showing-checklist.pdf" download style="background:#ffffff;">Download checklist</a>
    </div>
  </section>

  <section class="grid" style="margin-top: 16px;">
    <article class="card hover" style="padding:0; overflow:hidden;">
      <img src="/images/guides/jellyfin-ubuntu-low-power-hero.webp" alt="" loading="lazy" decoding="async" style="width:100%; height:150px; object-fit:contain; background:#f7f9fa;" />
      <div style="padding:1.1rem 1.05rem 1rem;">
        <div class="kicker">First project</div>
        <h2>Build a low-power Jellyfin server</h2>
        <p>
          Install Jellyfin on Ubuntu, give it access to your media folders, and avoid the usual permissions problems.
        </p>
        <a class="btn" href="/guides/jellyfin-ubuntu-low-power/">Start with Jellyfin →</a>
      </div>
    </article>

    <article class="card hover" style="padding:0; overflow:hidden;">
      <img src="/images/guides/best-mini-pc-specs-for-jellyfin-hero.webp" alt="" loading="lazy" decoding="async" style="width:100%; height:150px; object-fit:contain; background:#f7f9fa;" />
      <div style="padding:1.1rem 1.05rem 1rem;">
        <div class="kicker">Hardware</div>
        <h2>Pick a Jellyfin-ready mini PC</h2>
        <p>
          Choose CPU, RAM, storage, networking, and hardware transcoding support before buying a used mini PC.
        </p>
        <a class="btn" href="/guides/best-mini-pc-specs-for-jellyfin/">Read the specs guide →</a>
      </div>
    </article>

    <article class="card hover" style="padding:0; overflow:hidden;">
      <img src="/images/guides/backups-3-2-1-diagram.webp" alt="" loading="lazy" decoding="async" style="width:100%; height:150px; object-fit:contain; background:#f7f9fa;" />
      <div style="padding:1.1rem 1.05rem 1rem;">
        <div class="kicker">Backups</div>
        <h2>Make recovery boring</h2>
        <p>
          Set up a simple 3-2-1 backup approach before your home server becomes something you rely on.
        </p>
        <a class="btn" href="/guides/backups-3-2-1-home-server/">Build the backup habit →</a>
      </div>
    </article>
  </section>

  {priorityGuides.length ? (
    <section style="margin-top: 16px;">
      <div style="display:flex; align-items:end; justify-content:space-between; gap: 12px; flex-wrap:wrap;">
        <h2>High-value Jellyfin fixes</h2>
        <a class="btn" href="/guides/jellyfin/">View Jellyfin hub →</a>
      </div>

      <div class="grid" style="margin-top: 10px;">
        {priorityGuides.map((post) => (
          <article class="card hover">
            <h3 style="margin-top: 0;">
              <a href={`/guides/${post.slug}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <div>
              {(post.data.tags ?? []).slice(0, 4).map((tag) => (
                <span class="pill">#{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>
  ) : null}

  {latestJournal && (
    <section style="margin-top: 16px;">
      <div style="display:flex; align-items:end; justify-content:space-between; gap: 12px; flex-wrap:wrap;">
        <h2>Latest journal</h2>
        <a class="btn" href="/journal/">View all →</a>
      </div>

      <article class="card hover" style="margin-top: 10px; border-left:5px solid #2fa4a9;">
        <h3 style="margin-top: 0;">
          <a href={`/journal/${latestJournal.slug}/`}>{latestJournal.data.title}</a>
        </h3>
        <p>{latestJournal.data.description}</p>
        <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
          <span class="pill">
            {latestJournal.data.pubDate.toLocaleDateString("en-GB")}
          </span>
          {(latestJournal.data.tags ?? []).slice(0, 6).map((tag) => (
            <span class="pill">#{tag}</span>
          ))}
        </div>
      </article>
    </section>
  )}

  <section style="margin-top: 16px;">
    <div style="display:flex; align-items:end; justify-content:space-between; gap: 12px; flex-wrap:wrap;">
      <h2>Latest guides</h2>
      <a class="btn" href="/guides/">View all →</a>
    </div>

    <div class="grid" style="margin-top: 10px;">
      {featured.map((post) => (
        <article class="card hover">
          <h3 style="margin-top: 0;">
            <a href={`/guides/${post.slug}/`}>{post.data.title}</a>
          </h3>
          <p>{post.data.description}</p>
          <div>
            {(post.data.tags ?? []).slice(0, 4).map((tag) => (
              <span class="pill">#{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="grid" style="margin-top: 16px;">
    <div class="card" style="background:linear-gradient(180deg,#ffffff,#f3fbf9);">
      <div class="kicker">🔌 Low power</div>
      <h2>Efficiency first</h2>
      <p>Mini PCs, iGPU transcoding, and good-enough choices that keep wattage and noise down.</p>
    </div>
    <div class="card" style="background:linear-gradient(180deg,#ffffff,#f7faff);">
      <div class="kicker">🧰 Low drama</div>
      <h2>Maintainable</h2>
      <p>Setups you can support when you’re busy, tired, or both. Fewer moving parts, fewer surprises.</p>
    </div>
    <div class="card" style="background:linear-gradient(180deg,#ffffff,#f8fbfb);">
      <div class="kicker">🛡️ Secure default</div>
      <h2>Private remote access</h2>
      <p>Prefer private networking for remote access unless there is a clear reason to publish a service.</p>
    </div>
  </section>
</BaseLayout>
