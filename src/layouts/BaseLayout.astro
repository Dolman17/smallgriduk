---
import "../styles/global.css";

const {
  title = "SmallGrid.uk",
  description = "Small, useful systems. Clear technical guidance.",
  ogImage = "brand/smallgrid-logo.svg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// Base-path safe URLs (works on / and on subpaths like /smallgrid/)
const base = import.meta.env.BASE_URL;
const brandVersion = "2026-06-29-2";
const iconSvg = `${base}brand/smallgrid-icon.svg?v=${brandVersion}`;
const iconMonoSvg = `${base}brand/smallgrid-icon-mono.svg?v=${brandVersion}`;
const wordmarkDarkSvg = `${base}brand/smallgrid-wordmark-dark.svg?v=${brandVersion}`;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${base}${ogImage.replace(/^\//, "")}`;
const heroFixCss = `${base}hero-image-fix.css?v=2026-06-29-1`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
    />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9818469763709297"
      crossorigin="anonymous"
    ></script>

    <!-- Favicons (SVG-first) -->
    <link rel="icon" type="image/svg+xml" href={iconSvg} />
    <link rel="mask-icon" href={iconMonoSvg} color="#0E3D39" />

    <!-- Social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <style>
      :root {
        --sg-sticky-header-offset: 148px;
      }

      html {
        scroll-padding-top: calc(var(--sg-sticky-header-offset) + 18px);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }

      .page-with-ad-rails {
        display: grid;
        grid-template-columns: minmax(0, 980px);
        justify-content: center;
        gap: 1.25rem;
        max-width: 1480px;
        margin: 0 auto;
      }

      .ad-rail {
        display: none;
      }

      .ad-rail-box {
        position: sticky;
        top: calc(var(--sg-sticky-header-offset) + 18px);
        min-height: 600px;
        border: 1px dashed rgba(107, 115, 123, 0.35);
        border-radius: 0.9rem;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.48)),
          rgba(255, 255, 255, 0.64);
        color: rgba(107, 115, 123, 0.72);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        writing-mode: vertical-rl;
        box-shadow: 0 20px 45px -42px rgba(31, 36, 40, 0.45);
      }

      .site-search-bar {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        background: linear-gradient(90deg, #0b4f49, #0e3d39);
      }

      .site-search-inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0.65rem 1.25rem;
      }

      .site-search-form {
        display: flex;
        gap: 0.55rem;
        align-items: center;
      }

      .site-search-input {
        flex: 1;
        min-width: 0;
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 999px;
        padding: 0.62rem 0.95rem;
        background: rgba(255, 255, 255, 0.96);
        color: #1f2428;
        font: inherit;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
      }

      .site-search-input:focus {
        outline: 3px solid rgba(10, 102, 255, 0.24);
        border-color: rgba(10, 102, 255, 0.55);
      }

      .site-search-button {
        border: 1px solid rgba(255, 255, 255, 0.35);
        border-radius: 999px;
        padding: 0.62rem 0.95rem;
        background: #ffffff;
        color: #0e3d39;
        font-weight: 750;
        cursor: pointer;
        white-space: nowrap;
      }

      .article-hero .cover-image,
      .card > .cover-image {
        width: 100% !important;
        height: auto !important;
        max-height: none !important;
        object-fit: contain !important;
      }

      .article-hero {
        background: #f7f9fa;
      }

      @media (min-width: 980px) {
        .toc {
          top: calc(var(--sg-sticky-header-offset) + 18px) !important;
        }
      }

      @media (min-width: 1280px) {
        .page-with-ad-rails {
          grid-template-columns: 160px minmax(0, 980px) 160px;
          align-items: start;
        }

        .ad-rail {
          display: block;
        }
      }

      @media (min-width: 1500px) {
        .page-with-ad-rails {
          grid-template-columns: 200px minmax(0, 980px) 200px;
          gap: 1.5rem;
        }
      }

      @media (max-width: 720px) {
        :root {
          --sg-sticky-header-offset: 190px;
        }
      }

      @media (max-width: 520px) {
        .site-search-form {
          align-items: stretch;
          flex-direction: column;
        }

        .site-search-button {
          width: 100%;
        }
      }

      @media print {
        .ad-rail,
        .site-search-bar {
          display: none !important;
        }

        .site-header {
          position: static !important;
          backdrop-filter: none !important;
          -webkit-backdrop-filter: none !important;
        }
      }
    </style>
    <link rel="stylesheet" href={heroFixCss} />
  </head>

  <body>
    <div class="site-root">
      <header class="site-header">
        <div class="site-header-inner">
          <a class="site-logo" href={base} aria-label="SmallGrid.uk home">
            <span class="site-logo-main">
              <img
                class="site-logo-icon"
                src={iconSvg}
                width="28"
                height="28"
                alt="SmallGrid icon"
                decoding="async"
                loading="eager"
              />
              <img
                class="site-logo-wordmark"
                src={wordmarkDarkSvg}
                alt="SmallGrid.uk"
                decoding="async"
                loading="eager"
                style="filter: none;"
              />
            </span>
            <span class="site-logo-sub">Tiny tools. Solid systems.</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            <a class="site-nav-link" href={`${base}tutorials/`}>Tutorials</a>
            <a class="site-nav-link" href={`${base}guides/`}>Guides</a>
            <a class="site-nav-link" href={`${base}guides/jellyfin/`}>Jellyfin</a>
            <a class="site-nav-link" href={`${base}checklists/`}>Checklists</a>
            <a class="site-nav-link" href={`${base}journal/`}>Journal</a>
            <a class="site-nav-link" href={`${base}recommended-gear/`}>Recommended Gear</a>
            <a class="site-nav-link" href={`${base}about/`}>About</a>
          </nav>
        </div>

        <div class="site-search-bar" role="search">
          <div class="site-search-inner">
            <form class="site-search-form" action={`${base}search/`} method="get">
              <label class="sr-only" for="site-search-input">Search SmallGrid</label>
              <input
                id="site-search-input"
                class="site-search-input"
                type="search"
                name="q"
                placeholder="Search guides, tutorials, journal entries…"
                autocomplete="off"
              />
              <button class="site-search-button" type="submit">Search</button>
            </form>
          </div>
        </div>
      </header>

      <main class="page-shell">
        <div class="page-with-ad-rails">
          <aside class="ad-rail ad-rail-left" aria-label="Advertisement placeholder">
            <div class="ad-rail-box">Advertisement</div>
          </aside>

          <div class="page-inner">
            <article class="article-card">
              <slot />
            </article>
          </div>

          <aside class="ad-rail ad-rail-right" aria-label="Advertisement placeholder">
            <div class="ad-rail-box">Advertisement</div>
          </aside>
        </div>
      </main>

      <footer class="site-footer">
        <div class="site-footer-inner">
          <p class="site-footer-text">
            <img
              src={iconMonoSvg}
              width="16"
              height="16"
              alt=""
              aria-hidden="true"
              decoding="async"
              loading="lazy"
              style="vertical-align: -3px; margin-right: 6px;"
            />
            © {new Date().getFullYear()} SmallGrid.uk · Tiny tools. Solid systems.
            <span style="display:inline-flex; gap: 0.55rem; flex-wrap:wrap; margin-left: 0.55rem;">
              <a href={`${base}privacy/`}>Privacy</a>
              <a href={`${base}cookies/`}>Cookies</a>
              <a href={`${base}contact/`}>Contact</a>
              <a href={`${base}checklists/`}>Checklists</a>
              <a href={`${base}about/`}>About</a>
            </span>
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
