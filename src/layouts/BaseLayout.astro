---
import "../styles/global.css";
import "../styles/button-overrides.css";

const {
  title = "SmallGrid.uk",
  description = "Small, useful systems. Clear technical guidance.",
  ogImage = "brand/smallgrid-logo.svg",
  robots = "index,follow",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const guidePathMatch = Astro.url.pathname.match(/^\/guides\/([^/]+)\/?$/);
const guideSlug = guidePathMatch?.[1] ?? "";
const excludedGuidePages = new Set(["jellyfin"]);
const isGuideArticle = Boolean(guideSlug && !excludedGuidePages.has(guideSlug));

const getGuideTrustDetails = (slug: string) => {
  if (slug.includes("docker")) {
    return {
      environment: "Ubuntu Server, Docker, Jellyfin, Linux users, bind mounts and media-folder permissions.",
      verification: "Verified with host-path and container-path checks, bind-mount inspection, user and group checks, and direct file-access tests.",
    };
  }

  if (slug.includes("jellyfin")) {
    return {
      environment: "Ubuntu Server, Jellyfin and a Linux-based home media-server environment.",
      verification: "Verified with service status, logs, filesystem and permission checks, library scans, playback information, or client testing as relevant to the guide.",
    };
  }

  if (slug.includes("proxmox")) {
    return {
      environment: "A small Proxmox VE home-lab environment using practical virtual-machine, storage and recovery workflows.",
      verification: "Verified by carrying out the configuration, checking the resulting state, and documenting recovery or rollback steps where applicable.",
    };
  }

  if (slug.includes("backup") || slug.includes("snapshot")) {
    return {
      environment: "A Linux home-server environment using local storage, removable or secondary storage, and recovery-focused backup workflows.",
      verification: "Verified through backup inspection, restore-oriented checks, and comparison of snapshots, copies and off-site protection where relevant.",
    };
  }

  if (slug.includes("power") || slug.includes("mini-pc") || slug.includes("storage")) {
    return {
      environment: "Small low-power home-server hardware, mini PCs, storage devices and Linux-based services.",
      verification: "Verified using practical setup checks, observed hardware behaviour, power or storage measurements where available, and comparison against the stated requirements.",
    };
  }

  return {
    environment: "The SmallGrid home-lab test environment using Linux, small-form-factor hardware and self-hosted services.",
    verification: "Verified by following the documented process, checking the resulting configuration, and recording relevant failure, recovery and validation steps.",
  };
};

const guideTrustDetails = getGuideTrustDetails(guideSlug);

const base = import.meta.env.BASE_URL;
const brandVersion = "2026-06-29-2";
const iconSvg = `${base}brand/smallgrid-icon.svg?v=${brandVersion}`;
const iconMonoSvg = `${base}brand/smallgrid-icon-mono.svg?v=${brandVersion}`;
const wordmarkDarkSvg = `${base}brand/smallgrid-wordmark-dark.svg?v=${brandVersion}`;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${base}${ogImage.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <link rel="icon" type="image/svg+xml" href={iconSvg} />
    <link rel="mask-icon" href={iconMonoSvg} color="#0E3D39" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <style>
      :root {
        --sg-sticky-header-offset: 148px;
      }

      html {
        scroll-padding-top: calc(var(--sg-sticky-header-offset) + 18px);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }

      @media (max-width: 1100px) {
        .site-header-inner {
          align-items: center;
          flex-direction: column;
        }

        .site-nav {
          width: 100%;
          justify-content: center;
          flex-wrap: wrap;
          gap: 0.35rem 0.5rem;
        }

        .site-nav-link {
          font-size: 0.84rem;
          padding: 0.28rem 0.5rem;
        }
      }

      .page-with-ad-rails {
        display: grid;
        grid-template-columns: minmax(0, 980px);
        justify-content: center;
        gap: 1.25rem;
        max-width: 980px;
        margin: 0 auto;
      }

      .ad-rail,
      .ad-rail-box {
        display: none !important;
      }

      .site-search-bar {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        background: linear-gradient(90deg, #0b4f49, #0e3d39);
      }

      .site-search-inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0.65rem 1.25rem;
      }

      .site-search-form {
        display: flex;
        gap: 0.55rem;
        align-items: center;
      }

      .site-search-input {
        flex: 1;
        min-width: 0;
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 999px;
        padding: 0.62rem 0.95rem;
        background: rgba(255, 255, 255, 0.96);
        color: #1f2428;
        font: inherit;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
      }

      .site-search-input:focus {
        outline: 3px solid rgba(10, 102, 255, 0.24);
        border-color: rgba(10, 102, 255, 0.55);
      }

      .site-search-button {
        border: 1px solid rgba(255, 255, 255, 0.35);
        border-radius: 999px;
        padding: 0.62rem 0.95rem;
        background: #ffffff;
        color: #0e3d39;
        font-weight: 750;
        cursor: pointer;
        white-space: nowrap;
      }

      .article-hero .cover-image,
      .card > .cover-image {
        width: 100% !important;
        height: auto !important;
        max-height: none !important;
        object-fit: contain !important;
      }

      .article-hero {
        background: #f7f9fa;
      }

      .guide-trust-panel {
        margin-top: 1.5rem;
        padding: 1.15rem;
        border: 1px solid rgba(14, 61, 57, 0.18);
        border-left: 5px solid #0e3d39;
        border-radius: 0.9rem;
        background: linear-gradient(135deg, #f4fbfb, #ffffff);
      }

      .guide-trust-panel h2 {
        margin: 0 0 0.85rem;
        font-size: 1.15rem;
      }

      .guide-trust-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
      }

      .guide-trust-item {
        padding: 0.85rem;
        border: 1px solid rgba(107, 115, 123, 0.18);
        border-radius: 0.75rem;
        background: rgba(255, 255, 255, 0.78);
      }

      .guide-trust-label {
        display: block;
        margin-bottom: 0.25rem;
        color: #0e3d39;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .guide-trust-item p {
        margin: 0;
      }

      @media (min-width: 980px) {
        .toc {
          top: calc(var(--sg-sticky-header-offset) + 18px) !important;
        }
      }

      @media (max-width: 720px) {
        :root {
          --sg-sticky-header-offset: 230px;
        }

        .site-header-inner {
          padding-inline: 0.85rem;
        }

        .site-nav {
          gap: 0.25rem 0.35rem;
        }

        .site-nav-link {
          font-size: 0.8rem;
          padding: 0.25rem 0.42rem;
        }

        .guide-trust-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 520px) {
        :root {
          --sg-sticky-header-offset: 270px;
        }

        .site-search-form {
          align-items: stretch;
          flex-direction: column;
        }

        .site-search-button {
          width: 100%;
        }
      }

      @media print {
        .ad-rail,
        .site-search-bar {
          display: none !important;
        }

        .site-header {
          position: static !important;
          backdrop-filter: none !important;
          -webkit-backdrop-filter: none !important;
        }
      }
    </style>
  </head>

  <body>
    <div class="site-root">
      <header class="site-header">
        <div class="site-header-inner">
          <a class="site-logo" href={base} aria-label="SmallGrid.uk home">
            <span class="site-logo-main">
              <img
                class="site-logo-icon"
                src={iconSvg}
                width="28"
                height="28"
                alt="SmallGrid icon"
                decoding="async"
                loading="eager"
              />
              <img
                class="site-logo-wordmark"
                src={wordmarkDarkSvg}
                width="132"
                height="22"
                alt="SmallGrid.uk"
                decoding="async"
                loading="eager"
                style="filter: none;"
              />
            </span>
            <span class="site-logo-sub">Tiny tools. Solid systems.</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            <a class="site-nav-link" href={base}>Home</a>
            <a class="site-nav-link" href={`${base}tutorials/`}>Tutorials</a>
            <a class="site-nav-link" href={`${base}guides/`}>Guides</a>
            <a class="site-nav-link" href={`${base}guides/jellyfin/`}>Jellyfin</a>
            <a class="site-nav-link" href={`${base}checklists/`}>Checklists</a>
            <a class="site-nav-link" href={`${base}journal/`}>Journal</a>
            <a class="site-nav-link" href={`${base}recommended-gear/`}>Recommended Gear</a>
            <a class="site-nav-link" href={`${base}partner-projects/`}>Partner Projects</a>
            <a class="site-nav-link" href={`${base}about/`}>About</a>
          </nav>
        </div>

        <div class="site-search-bar" role="search">
          <div class="site-search-inner">
            <form class="site-search-form" action={`${base}search/`} method="get">
              <label class="sr-only" for="site-search-input">Search SmallGrid</label>
              <input
                id="site-search-input"
                class="site-search-input"
                type="search"
                name="q"
                placeholder="Search guides, tutorials, journal entries…"
                autocomplete="off"
              />
              <button class="site-search-button" type="submit">Search</button>
            </form>
          </div>
        </div>
      </header>

      <main class="page-shell">
        <div class="page-with-ad-rails">
          <aside class="ad-rail ad-rail-left" aria-hidden="true"></aside>

          <div class="page-inner">
            <article class="article-card">
              <slot />

              {isGuideArticle ? (
                <section class="guide-trust-panel" aria-labelledby="guide-trust-title">
                  <p class="kicker">About this guide</p>
                  <h2 id="guide-trust-title">Written, tested and maintained by SmallGrid</h2>

                  <div class="guide-trust-grid">
                    <div class="guide-trust-item">
                      <span class="guide-trust-label">Written by</span>
                      <p><a href={`${base}about/`}><strong>Sean Dolman</strong></a>, creator of SmallGrid.uk.</p>
                    </div>

                    <div class="guide-trust-item">
                      <span class="guide-trust-label">Dates</span>
                      <p>
                        Published <time id="guide-trust-published">date shown in the guide metadata</time>.
                        Updated <time id="guide-trust-updated">when the guide was last reviewed</time>.
                      </p>
                    </div>

                    <div class="guide-trust-item">
                      <span class="guide-trust-label">Tested environment</span>
                      <p>{guideTrustDetails.environment}</p>
                    </div>

                    <div class="guide-trust-item">
                      <span class="guide-trust-label">How it was verified</span>
                      <p>{guideTrustDetails.verification}</p>
                    </div>
                  </div>

                  <p style="margin:0.9rem 0 0;">
                    Found an error, outdated step or unclear instruction?
                    <a href={`${base}contact/?subject=${encodeURIComponent(`Correction: ${title}`)}`}>Report a correction</a>.
                  </p>
                </section>
              ) : null}
            </article>
          </div>

          <aside class="ad-rail ad-rail-right" aria-hidden="true"></aside>
        </div>
      </main>

      <footer class="site-footer">
        <div class="site-footer-inner">
          <p class="site-footer-text">
            <img
              src={iconMonoSvg}
              width="16"
              height="16"
              alt=""
              aria-hidden="true"
              decoding="async"
              loading="lazy"
              style="vertical-align: -3px; margin-right: 6px;"
            />
            © {new Date().getFullYear()} SmallGrid.uk · Tiny tools. Solid systems.
            <span style="display:inline-flex; gap: 0.55rem; flex-wrap:wrap; margin-left: 0.55rem;">
              <a href={`${base}privacy/`}>Privacy</a>
              <a href={`${base}cookies/`}>Cookies</a>
              <a href={`${base}contact/`}>Contact</a>
              <a href={`${base}checklists/`}>Checklists</a>
              <a href={`${base}partner-projects/`}>Partner Projects</a>
              <a href={`${base}about/`}>About</a>
            </span>
          </p>
        </div>
      </footer>
    </div>

    {isGuideArticle ? (
      <script is:inline>
        (() => {
          const formatDate = (value) => {
            if (!value) return "not recorded";
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return "not recorded";
            return date.toLocaleDateString("en-GB", {
              day: "2-digit",
              month: "short",
              year: "numeric",
            });
          };

          const schemas = Array.from(document.querySelectorAll('script[type="application/ld+json"]'));
          let article = null;

          for (const schema of schemas) {
            try {
              const parsed = JSON.parse(schema.textContent || "null");
              const items = Array.isArray(parsed) ? parsed : [parsed];
              article = items.find((item) => item && (item["@type"] === "Article" || item["@type"] === "TechArticle"));
              if (article) break;
            } catch (_) {
              // Ignore unrelated or malformed structured-data blocks.
            }
          }

          const published = document.getElementById("guide-trust-published");
          const updated = document.getElementById("guide-trust-updated");

          if (published && article?.datePublished) {
            published.textContent = formatDate(article.datePublished);
            published.setAttribute("datetime", article.datePublished);
          }

          if (updated && article?.dateModified) {
            updated.textContent = formatDate(article.dateModified);
            updated.setAttribute("datetime", article.dateModified);
          }

          document.querySelectorAll(".guide-author").forEach((element) => {
            element.textContent = "Sean Dolman";
          });
        })();
      </script>
    ) : null}
  </body>
</html>