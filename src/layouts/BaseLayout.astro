---
import "../styles/global.css";

const {
  title = "SmallGrid.uk",
  description = "Small, useful systems. Clear technical guidance.",
  ogImage = "brand/smallgrid-logo.svg",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// Base-path safe URLs (works on / and on subpaths like /smallgrid/)
const base = import.meta.env.BASE_URL;
const brandVersion = "2026-06-29-2";
const iconSvg = `${base}brand/smallgrid-icon.svg?v=${brandVersion}`;
const iconMonoSvg = `${base}brand/smallgrid-icon-mono.svg?v=${brandVersion}`;
const wordmarkDarkSvg = `${base}brand/smallgrid-wordmark-dark.svg?v=${brandVersion}`;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${base}${ogImage.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
    />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9818469763709297"
      crossorigin="anonymous"
    ></script>

    <!-- Favicons (SVG-first) -->
    <link rel="icon" type="image/svg+xml" href={iconSvg} />
    <link rel="mask-icon" href={iconMonoSvg} color="#0E3D39" />

    <!-- Social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <style>
      .page-with-ad-rails {
        display: grid;
        grid-template-columns: minmax(0, 980px);
        justify-content: center;
        gap: 1.25rem;
        max-width: 1480px;
        margin: 0 auto;
      }

      .ad-rail {
        display: none;
      }

      .ad-rail-box {
        position: sticky;
        top: 92px;
        min-height: 600px;
        border: 1px dashed rgba(107, 115, 123, 0.35);
        border-radius: 0.9rem;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.48)),
          rgba(255, 255, 255, 0.64);
        color: rgba(107, 115, 123, 0.72);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        writing-mode: vertical-rl;
        box-shadow: 0 20px 45px -42px rgba(31, 36, 40, 0.45);
      }

      @media (min-width: 1280px) {
        .page-with-ad-rails {
          grid-template-columns: 160px minmax(0, 980px) 160px;
          align-items: start;
        }

        .ad-rail {
          display: block;
        }
      }

      @media (min-width: 1500px) {
        .page-with-ad-rails {
          grid-template-columns: 200px minmax(0, 980px) 200px;
          gap: 1.5rem;
        }
      }

      @media print {
        .ad-rail {
          display: none !important;
        }
      }
    </style>
  </head>

  <body>
    <div class="site-root">
      <header class="site-header">
        <div class="site-header-inner">
          <a class="site-logo" href={base} aria-label="SmallGrid.uk home">
            <span class="site-logo-main">
              <img
                class="site-logo-icon"
                src={iconSvg}
                width="28"
                height="28"
                alt="SmallGrid icon"
                decoding="async"
                loading="eager"
              />
              <img
                class="site-logo-wordmark"
                src={wordmarkDarkSvg}
                alt="SmallGrid.uk"
                decoding="async"
                loading="eager"
                style="filter: none;"
              />
            </span>
            <span class="site-logo-sub">Tiny tools. Solid systems.</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            <a class="site-nav-link" href={`${base}tutorials/`}>Tutorials</a>
            <a class="site-nav-link" href={`${base}guides/`}>Guides</a>
            <a class="site-nav-link" href={`${base}about/`}>About</a>
          </nav>
        </div>
      </header>

      <main class="page-shell">
        <div class="page-with-ad-rails">
          <aside class="ad-rail ad-rail-left" aria-label="Advertisement placeholder">
            <div class="ad-rail-box">Advertisement</div>
          </aside>

          <div class="page-inner">
            <article class="article-card">
              <slot />
            </article>
          </div>

          <aside class="ad-rail ad-rail-right" aria-label="Advertisement placeholder">
            <div class="ad-rail-box">Advertisement</div>
          </aside>
        </div>
      </main>

      <footer class="site-footer">
        <div class="site-footer-inner">
          <p class="site-footer-text">
            <img
              src={iconMonoSvg}
              width="16"
              height="16"
              alt=""
              aria-hidden="true"
              decoding="async"
              loading="lazy"
              style="vertical-align: -3px; margin-right: 6px;"
            />
            © {new Date().getFullYear()} SmallGrid.uk · Tiny tools. Solid systems.
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
